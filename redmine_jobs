### Redmine cron jobs
# Sync EEA GitHub
15 6 * * * su redmine -c "/var/local/redmine/crons/redmine_github_sync.sh" 2>&1 | logger
# Redmine helpdesk plugin incoming email
*/5 * * * * /var/local/redmine/crons/helpdesk.sh 2>&1  | logger
# Redmine Taskman default email inbox ( reply to default email or new ticket )
*/5 * * * * /var/local/redmine/crons/taskman_email.sh 2>&1 | logger
# Redmine EEA Entra ID hourly syncronization of user accounts
0 * * * *  /var/local/redmine/crons/eea_entra_id_sync_users.sh 2>&1 | logger
# Redmine EEA Entra ID daily syncronization of user groups
15 4 * * *  /var/local/redmine/crons/eea_entra_id_sync_groups.sh 2>&1 | logger
# Rails Pulse jobs (guarded with DB advisory lock, safe across multiple pods)
*/5 * * * * /var/local/redmine/crons/rails_pulse_job.sh RailsPulse::SummaryJob rails_pulse_summary 2>&1 | logger
17 3 * * * /var/local/redmine/crons/rails_pulse_job.sh RailsPulse::CleanupJob rails_pulse_cleanup 2>&1 | logger
